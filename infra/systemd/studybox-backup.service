[Unit]
Description=StudyBox AI PostgreSQL backup
After=postgresql.service
Wants=postgresql.service

[Service]
Type=oneshot
User=studybox
Group=studybox
EnvironmentFile=/etc/studybox-ai/api.env
Environment=BACKUP_DIR=/srv/studybox-backups
ExecStart=/bin/sh /srv/studybox-ai/current/infra/backup.sh
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/srv/studybox-backups
